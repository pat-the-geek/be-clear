# ─────────────────────────────────────────────
# be.CLEAR — Variables d'environnement
#
# Pour une instance nommée "be-clear-1" :
#   cp .env.example .env.be-clear-1
#   Éditer .env.be-clear-1 (mots de passe, ports uniques…)
#   ./deploy.sh --instance=be-clear-1
#
# Pour l'instance par défaut :
#   cp .env.example .env
#   ./deploy.sh
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=beclear
POSTGRES_PASSWORD=changeme
POSTGRES_DB=beclear

# Meilisearch
MEILISEARCH_MASTER_KEY=changeme_meilisearch_key

# JWT
SECRET_KEY=changeme_jwt_secret_very_long_random_string

# Ollama (instance partagée — serveur dédié)
OLLAMA_URL=http://100.72.122.51:11434

# Vault Obsidian (chemin sur l'hôte — monté dans /vault dans le container)
# Laisser vide si non utilisé
OBSIDIAN_VAULT_PATH_HOST=

# URL publique du backend (utilisée par le frontend et les rapports RPT)
# Adapter si le port backend est modifié (BACKEND_PORT)
PUBLIC_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ─── MCP — Model Context Protocol ────────────────────────────────────────────
# Token API be.CLEAR associé au serveur MCP (créé dans l'interface admin).
# Laisser vide désactive l'authentification MCP (déconseillé en production).
BECLEAR_MCP_TOKEN=

# ─── Ports exposés sur l'hôte ────────────────────────────────────────────────
# Modifier ces valeurs pour chaque instance afin d'éviter les conflits de ports.
# Exemple pour une deuxième instance : 3001, 8002, 7701, 6380, 5433
FRONTEND_PORT=3000
BACKEND_PORT=8000
MCP_PORT=8001
MEILI_PORT=7700
REDIS_PORT=6379
POSTGRES_PORT=5432
