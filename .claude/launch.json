{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceRoot}/frontend",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Backend (FastAPI / uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceRoot}/backend",
      "port": 8000
    },
    {
      "name": "Full stack (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "cwd": "${workspaceRoot}",
      "port": 3000
    }
  ]
}
